# ─── Site ────────────────────────────────────────────────────────────────────
# Public base URL of the site (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://cacmiraclecenter.org

# ─── CMS (Sanity) ────────────────────────────────────────────────────────────
# Uncomment and fill in when you connect a headless CMS.
# See src/lib/cms.ts for the integration point.
# SANITY_PROJECT_ID=your_project_id
# SANITY_DATASET=production
# SANITY_API_TOKEN=your_read_token

# ─── CMS (Contentful) ────────────────────────────────────────────────────────
# CONTENTFUL_SPACE_ID=your_space_id
# CONTENTFUL_ACCESS_TOKEN=your_access_token

# ─── Email / Newsletter ───────────────────────────────────────────────────────
# Used by the newsletter subscription forms.
# CONVERTKIT_API_KEY=your_api_key
# CONVERTKIT_FORM_ID=your_form_id

# ─── Contact Form ─────────────────────────────────────────────────────────────
# Formspree endpoint for the contact form (no backend needed).
# NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your_id

# ─── Analytics ────────────────────────────────────────────────────────────────
# Plausible or Vercel Analytics — no personal data collected.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=cacmiraclecenter.org
